<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Registrar Materia</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
    <div>
        <label class="block text-gray-700 font-medium">Profesor asignado</label>
        {{#profesor}}
            <p class="text-violet-700 font-semibold">{{nombre}} {{apellido}}</p>
        {{/profesor}}
        {{^profesor}}
            <p class="text-gray-500">No hay profesor asignado.</p>
        {{/profesor}}
        </div>

        <div>
        <label class="block text-gray-700 font-medium">Alumnos inscriptos</label>
        <ul class="bg-gray-50 border border-gray-200 rounded-lg p-3 space-y-1">
            {{#alumnos}}
                <li>{{nombre}} {{apellido}} — {{correo}}
                (nota: {{nota}} / fecha: {{fecha}})
            </li>
            {{/alumnos}}
            {{^alumnos}}
                <li class="text-gray-500">No hay alumnos inscriptos.</li>
            {{/alumnos}}
        </ul>
    </div>

</body>
</html>
