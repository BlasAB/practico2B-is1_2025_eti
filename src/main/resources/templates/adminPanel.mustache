<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Administración</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
    <div class="max-w-6xl mx-auto">

        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">Panel de Administración</h1>
                <p class="text-gray-500 text-sm mt-1">ABM de Alumnos y Profesores</p>
            </div>
            <a href="/" class="text-gray-500 hover:text-gray-700 text-sm">&larr; Volver al inicio</a>
        </div>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg mb-6">
            {{successMessage}}
        </div>
        {{/successMessage}}
        {{#error}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-6">
            {{error}}
        </div>
        {{/error}}

        <!-- ===================== ALUMNOS ===================== -->
        <div class="bg-white rounded-2xl shadow-md mb-8 overflow-hidden">
            <div class="flex items-center justify-between px-6 py-4 bg-blue-50 border-b border-blue-100">
                <h2 class="text-xl font-bold text-blue-700">Alumnos</h2>
                <a href="/alumno/registrar"
                   class="inline-flex items-center gap-1 bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition text-sm font-medium">
                    + Nuevo Alumno
                </a>
            </div>

            {{#alumnos}}
            <div class="border-b border-gray-100 px-6 py-4">
                <div class="flex items-start justify-between">
                    <div>
                        <p class="font-semibold text-gray-800">{{nombre}} {{apellido}}</p>
                        <p class="text-gray-500 text-sm">{{correo}} &bull; DNI: {{dni}}</p>
                    </div>
                    <div class="flex gap-2 ml-4">
                        <!-- Botón editar (abre modal inline) -->
                        <button onclick="toggleEdit('alumno-{{id}}')"
                                class="text-xs bg-yellow-100 text-yellow-700 border border-yellow-300 px-3 py-1 rounded-lg hover:bg-yellow-200 transition font-medium">
                            Editar
                        </button>
                        <!-- Botón eliminar -->
                        <a href="/alumno/eliminar/{{id}}"
                           onclick="return confirm('¿Eliminar al alumno {{nombre}} {{apellido}}?')"
                           class="text-xs bg-red-100 text-red-700 border border-red-300 px-3 py-1 rounded-lg hover:bg-red-200 transition font-medium">
                            Eliminar
                        </a>
                    </div>
                </div>
                <!-- Formulario de edición (oculto por defecto) -->
                <div id="alumno-{{id}}" class="hidden mt-4 pt-4 border-t border-gray-100">
                    <form action="/alumno/editar/{{id}}" method="POST" class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Nombre</label>
                            <input type="text" name="nombre" value="{{nombre}}" required
                                   class="w-full px-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Apellido</label>
                            <input type="text" name="apellido" value="{{apellido}}" required
                                   class="w-full px-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Correo</label>
                            <input type="email" name="correo" value="{{correo}}" required
                                   class="w-full px-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">DNI</label>
                            <input type="text" name="dni" value="{{dni}}" required
                                   class="w-full px-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
                        </div>
                        <div class="col-span-2 flex gap-2 justify-end">
                            <button type="button" onclick="toggleEdit('alumno-{{id}}')"
                                    class="text-sm text-gray-500 hover:text-gray-700 px-3 py-1.5">Cancelar</button>
                            <button type="submit"
                                    class="bg-blue-600 text-white text-sm px-4 py-1.5 rounded-lg hover:bg-blue-700 transition font-medium">
                                Guardar cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            {{/alumnos}}

            {{^alumnos}}
            <div class="px-6 py-10 text-center text-gray-400">
                <p>No hay alumnos registrados.</p>
            </div>
            {{/alumnos}}
        </div>

        <!-- ===================== PROFESORES ===================== -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden">
            <div class="flex items-center justify-between px-6 py-4 bg-green-50 border-b border-green-100">
                <h2 class="text-xl font-bold text-green-700">Profesores</h2>
                <a href="/profesor/registrar"
                   class="inline-flex items-center gap-1 bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition text-sm font-medium">
                    + Nuevo Profesor
                </a>
            </div>

            {{#profesores}}
            <div class="border-b border-gray-100 px-6 py-4">
                <div class="flex items-start justify-between">
                    <div>
                        <p class="font-semibold text-gray-800">{{nombre}} {{apellido}}</p>
                        <p class="text-gray-500 text-sm">{{correo}} &bull; DNI: {{dni}}</p>
                    </div>
                    <div class="flex gap-2 ml-4">
                        <button onclick="toggleEdit('profesor-{{id}}')"
                                class="text-xs bg-yellow-100 text-yellow-700 border border-yellow-300 px-3 py-1 rounded-lg hover:bg-yellow-200 transition font-medium">
                            Editar
                        </button>
                        <a href="/profesor/eliminar/{{id}}"
                           onclick="return confirm('¿Eliminar al profesor {{nombre}} {{apellido}}?')"
                           class="text-xs bg-red-100 text-red-700 border border-red-300 px-3 py-1 rounded-lg hover:bg-red-200 transition font-medium">
                            Eliminar
                        </a>
                    </div>
                </div>
                <div id="profesor-{{id}}" class="hidden mt-4 pt-4 border-t border-gray-100">
                    <form action="/profesor/editar/{{id}}" method="POST" class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Nombre</label>
                            <input type="text" name="nombre" value="{{nombre}}" required
                                   class="w-full px-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-green-400">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Apellido</label>
                            <input type="text" name="apellido" value="{{apellido}}" required
                                   class="w-full px-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-green-400">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Correo</label>
                            <input type="email" name="correo" value="{{correo}}" required
                                   class="w-full px-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-green-400">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">DNI</label>
                            <input type="text" name="dni" value="{{dni}}" required
                                   class="w-full px-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-green-400">
                        </div>
                        <div class="col-span-2 flex gap-2 justify-end">
                            <button type="button" onclick="toggleEdit('profesor-{{id}}')"
                                    class="text-sm text-gray-500 hover:text-gray-700 px-3 py-1.5">Cancelar</button>
                            <button type="submit"
                                    class="bg-green-600 text-white text-sm px-4 py-1.5 rounded-lg hover:bg-green-700 transition font-medium">
                                Guardar cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            {{/profesores}}

            {{^profesores}}
            <div class="px-6 py-10 text-center text-gray-400">
                <p>No hay profesores registrados.</p>
            </div>
            {{/profesores}}
        </div>

    </div>

    <script>
        function toggleEdit(id) {
            const el = document.getElementById(id);
            el.classList.toggle('hidden');
        }
    </script>
</body>
</html>
