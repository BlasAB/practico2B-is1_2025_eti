<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Materias del Profesor</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
    <div class="max-w-3xl mx-auto bg-white rounded-2xl shadow-md p-6">
        <h2 class="text-2xl font-bold text-violet-700 mb-6">
            Materias dictadas por {{nombre}} {{apellido}}
        </h2>

        {{#materias}}
        <div class="p-4 mb-3 bg-violet-50 border border-violet-200 rounded-lg">
            <h3 class="text-lg font-semibold text-violet-800">{{nombre}} ({{codigo}})</h3>
            <p class="text-gray-700">{{descripcion}}</p>
            <div class="mt-2 flex gap-3">
                <a href="/materia/editar/{{id}}" 
                   class="text-sm bg-blue-600 text-white px-3 py-1 rounded hover:bg-blue-700">
                   Editar
                </a>
                <a href="/materia/eliminar/{{id}}" 
                   class="text-sm bg-red-600 text-white px-3 py-1 rounded hover:bg-red-700">
                   Eliminar
                </a>
            </div>
        </div>
        {{/materias}}

        {{^materias}}
        <p class="text-gray-600">Este profesor aún no tiene materias asignadas.</p>
        {{/materias}}

        <div class="mt-6">
            <a href="/profesores/listar" 
               class="text-gray-500 hover:text-gray-700">← Volver al listado de profesores</a>
        </div>
    </div>
</body>
</html>
