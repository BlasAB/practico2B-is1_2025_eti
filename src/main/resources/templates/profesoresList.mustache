<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Profesores</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-4">
    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-8">Lista de Profesores Registrados</h1>

        {{#profesores}}
        <div class="p-4 mb-3 bg-white rounded-lg shadow-sm flex justify-between items-center">
        <div>
            <h3 class="text-lg font-semibold">{{nombre}} {{apellido}}</h3>
            <p class="text-gray-600">{{correo}}</p>
        </div>
        <div class="flex items-center gap-3">
            <p class="text-gray-700">DNI: {{dni}}</p>
            <a href="/profesor/{{id}}/materias" 
            class="text-sm bg-violet-600 text-white px-3 py-1 rounded hover:bg-violet-700 transition">
            Ver materias
            </a>
        </div>
        </div>
        {{/profesores}}


        {{^profesores}}
        <div class="bg-white rounded-lg shadow-md p-8 text-center">
            <p class="text-gray-600 text-lg">No hay profesores registrados.</p>
        </div>
        {{/profesores}}

        <div class="mt-8 text-center space-y-4">
            <a href="/profesor/registrar" 
               class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition duration-200 font-medium">
                Registrar Nuevo Profesor
            </a>
            <br>
            <a href="/" 
               class="inline-block bg-gray-600 text-white px-6 py-3 rounded-lg hover:bg-gray-700 transition duration-200 font-medium">
                Volver al Inicio
            </a>
        </div>
    </div>
</body>
</html>