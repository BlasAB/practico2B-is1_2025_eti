<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Materias</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
    <div class="max-w-4xl mx-auto">

        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">Materias</h1>
                <p class="text-gray-500 text-sm mt-1">Alta, edición, eliminación y carga de notas</p>
            </div>
            <a href="/dashboard" class="text-gray-500 hover:text-gray-700 text-sm">&larr; Volver al panel</a>
        </div>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg mb-6">
            {{successMessage}}
        </div>
        {{/successMessage}}
        {{#error}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-6">
            {{error}}
        </div>
        {{/error}}

        <!-- Tabla de materias -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden">
            <div class="flex items-center justify-between px-6 py-4 bg-violet-50 border-b border-violet-100">
                <h2 class="text-xl font-bold text-violet-700">Materias registradas</h2>
                <a href="/materia/registrar"
                class="inline-flex items-center gap-1 bg-violet-600 text-white px-4 py-2 rounded-lg hover:bg-violet-700 transition text-sm font-medium">
                    + Nueva materia
                </a>
            </div>

            {{#materias}}
            <div class="border-b border-gray-100 px-6 py-4">
                <div class="flex items-start justify-between">
                    <div>
                        <p class="font-semibold text-gray-800">{{nombre}}</p>
                        <p class="text-gray-500 text-sm">
                            Código: <span class="font-medium">{{codigo}}</span>
                            {{#descripcion}}&bull; {{descripcion}}{{/descripcion}}
                        </p>
                    </div>
                    <div class="flex gap-2 ml-4 flex-shrink-0">
                        <a href="/materia/{{id}}/notas"
                           class="text-xs bg-violet-100 text-violet-700 border border-violet-300 px-3 py-1 rounded-lg hover:bg-violet-200 transition font-medium">
                            Notas
                        </a>
                        <a href="/materia/editar/{{id}}"
                           class="text-xs bg-yellow-100 text-yellow-700 border border-yellow-300 px-3 py-1 rounded-lg hover:bg-yellow-200 transition font-medium">
                            Editar
                        </a>
                        <a href="/materia/eliminar/{{id}}"
                           onclick="return confirm('¿Eliminar la materia {{nombre}}? Se eliminarán también todas las notas asociadas.')"
                           class="text-xs bg-red-100 text-red-700 border border-red-300 px-3 py-1 rounded-lg hover:bg-red-200 transition font-medium">
                            Eliminar
                        </a>
                    </div>
                </div>
            </div>
            {{/materias}}

            {{^materias}}
            <div class="px-6 py-10 text-center text-gray-400">
                <p>No hay materias registradas.</p>
            </div>
            {{/materias}}
        </div>


    </div>
</body>
</html>
