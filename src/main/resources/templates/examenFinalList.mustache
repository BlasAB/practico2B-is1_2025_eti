<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fechas de Exámenes Finales</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
    <div class="max-w-4xl mx-auto">

        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">Fechas de Exámenes Finales</h1>
                <p class="text-gray-500 text-sm mt-1">Alta, edición y eliminación de fechas</p>
            </div>
            <a href="/dashboard" class="text-gray-500 hover:text-gray-700 text-sm">&larr; Volver al panel</a>
        </div>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg mb-6">
            {{successMessage}}
        </div>
        {{/successMessage}}
        {{#error}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-6">
            {{error}}
        </div>
        {{/error}}

        <!-- Tabla de exámenes -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden">
            <div class="flex items-center justify-between px-6 py-4 bg-violet-50 border-b border-violet-100">
                <h2 class="text-xl font-bold text-violet-700">Exámenes registrados</h2>
                <a href="/examen/registrar"
                   class="inline-flex items-center gap-1 bg-violet-600 text-white px-4 py-2 rounded-lg hover:bg-violet-700 transition text-sm font-medium">
                    + Nueva fecha
                </a>
            </div>

            {{#examenes}}
            <div class="border-b border-gray-100 px-6 py-4">
                <div class="flex items-start justify-between">
                    <div>
                        <p class="font-semibold text-gray-800">{{materiaNombre}}</p>
                        <p class="text-gray-500 text-sm">
                            {{fecha}}
                            {{#hora}}&bull; {{hora}}{{/hora}}
                            {{#turno}}&bull; Turno {{turno}}{{/turno}}
                        </p>
                        {{#observaciones}}
                        <p class="text-gray-400 text-xs mt-1">{{observaciones}}</p>
                        {{/observaciones}}
                    </div>
                    <div class="flex gap-2 ml-4">
                        <a href="/examen/editar/{{id}}"
                           class="text-xs bg-yellow-100 text-yellow-700 border border-yellow-300 px-3 py-1 rounded-lg hover:bg-yellow-200 transition font-medium">
                            Editar
                        </a>
                        <a href="/examen/eliminar/{{id}}"
                           onclick="return confirm('¿Eliminar este examen de {{materiaNombre}} del {{fecha}}?')"
                           class="text-xs bg-red-100 text-red-700 border border-red-300 px-3 py-1 rounded-lg hover:bg-red-200 transition font-medium">
                            Eliminar
                        </a>
                    </div>
                </div>
            </div>
            {{/examenes}}

            {{^examenes}}
            <div class="px-6 py-10 text-center text-gray-400">
                <p>No hay fechas de exámenes registradas.</p>
            </div>
            {{/examenes}}
        </div>

        {{!-- TODO: Cuando se implemente el calendario de exámenes, este listado
              será la fuente de datos para la vista calendario (issue correspondiente). --}}

    </div>
</body>
</html>
