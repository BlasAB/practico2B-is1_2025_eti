<h1 class="text-2xl font-bold mb-6 text-center">
  {{#profesor}}Editar{{/profesor}}{{^profesor}}Registrar{{/profesor}} Profesor
</h1>

<form action="{{#profesor}}/profesor/editar/{{id}}{{/profesor}}{{^profesor}}/profesor/registrar{{/profesor}}" 
      method="POST" class="space-y-4">

  <div>
    <label for="nombre" class="block font-semibold">Nombre:</label>
    <input type="text" id="nombre" name="nombre" value="{{nombre}}" required class="w-full border rounded px-3 py-2">
  </div>

  <div>
    <label for="apellido" class="block font-semibold">Apellido:</label>
    <input type="text" id="apellido" name="apellido" value="{{apellido}}" required class="w-full border rounded px-3 py-2">
  </div>

  <div>
    <label for="correo" class="block font-semibold">Correo electrónico:</label>
    <input type="email" id="correo" name="correo" value="{{correo}}" required class="w-full border rounded px-3 py-2">
  </div>

  <div>
    <label for="dni" class="block font-semibold">DNI:</label>
    <input type="text" id="dni" name="dni" value="{{dni}}" required class="w-full border rounded px-3 py-2">
  </div>

  <div class="flex justify-between mt-6">
    <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
      Guardar
    </button>
    <a href="/profesores/listar" class="bg-gray-300 text-gray-800 px-4 py-2 rounded hover:bg-gray-400">
      Cancelar
    </a>
  </div>
</form>
