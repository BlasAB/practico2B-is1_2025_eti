<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#esEdicion}}Editar Fecha de Examen{{/esEdicion}}{{^esEdicion}}Nueva Fecha de Examen{{/esEdicion}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-violet-50 to-purple-100 flex items-center justify-center min-h-screen p-4">
    <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md">

        <div class="flex items-center mb-6">
            <svg class="w-8 h-8 text-violet-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <h1 class="text-2xl font-bold text-gray-800">
                {{#esEdicion}}Editar Fecha de Examen{{/esEdicion}}{{^esEdicion}}Nueva Fecha de Examen{{/esEdicion}}
            </h1>
        </div>

        {{#error}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-4">
            {{error}}
        </div>
        {{/error}}

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg mb-4">
            {{successMessage}}
        </div>
        {{/successMessage}}

        {{#esEdicion}}
        <form action="/examen/editar/{{id}}" method="POST" class="space-y-4">
        {{/esEdicion}}
        {{^esEdicion}}
        <form action="/examen/registrar" method="POST" class="space-y-4">
        {{/esEdicion}}

            <div>
                <label for="materia_id" class="block text-gray-700 text-sm font-medium mb-1">Materia:</label>
                <select id="materia_id" name="materia_id" required
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500 bg-white">
                    <option value="">-- Seleccionar materia --</option>
                    {{#materias}}
                    <option value="{{id}}" {{#seleccionada}}selected{{/seleccionada}}>{{nombre}} ({{codigo}})</option>
                    {{/materias}}
                </select>
            </div>

            <div>
                <label for="fecha" class="block text-gray-700 text-sm font-medium mb-1">Fecha:</label>
                <input type="date" id="fecha" name="fecha" value="{{fecha}}" required
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500">
            </div>

            <div>
                <label for="hora" class="block text-gray-700 text-sm font-medium mb-1">Hora:</label>
                <input type="time" id="hora" name="hora" value="{{hora}}"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500">
            </div>

            <div>
                <label for="turno" class="block text-gray-700 text-sm font-medium mb-1">Turno:</label>
                <select id="turno" name="turno"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500 bg-white">
                    <option value="">-- Seleccionar turno --</option>
                    <option value="Febrero"   {{#turnoFebrero}}selected{{/turnoFebrero}}>Febrero</option>
                    <option value="Julio"     {{#turnoJulio}}selected{{/turnoJulio}}>Julio</option>
                    <option value="Diciembre" {{#turnoDiciembre}}selected{{/turnoDiciembre}}>Diciembre</option>
                </select>
            </div>

            <div>
                <label for="observaciones" class="block text-gray-700 text-sm font-medium mb-1">Observaciones:</label>
                <textarea id="observaciones" name="observaciones" rows="3"
                          placeholder="Ej: Aula 12, traer calculadora..."
                          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500 resize-none">{{observaciones}}</textarea>
            </div>

            <button type="submit"
                    class="w-full bg-violet-600 text-white py-2 px-4 rounded-lg hover:bg-violet-700 font-semibold transition mt-2">
                {{#esEdicion}}Guardar cambios{{/esEdicion}}{{^esEdicion}}Registrar Examen{{/esEdicion}}
            </button>
        </form>

        <div class="mt-4 text-center">
            <a href="/examenes/listar" class="text-gray-500 hover:text-gray-700 text-sm">&larr; Volver a la lista</a>
        </div>
    </div>
</body>
</html>
