<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Materias Disponibles</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
    <div class="max-w-3xl mx-auto">

        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">Materias Disponibles</h1>
                <p class="text-gray-500 text-sm mt-1">Inscribite a las materias durante el período activo</p>
            </div>
            <a href="/dashboard" class="text-gray-500 hover:text-gray-700 text-sm">&larr; Volver al panel</a>
        </div>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg mb-6">
            {{successMessage}}
        </div>
        {{/successMessage}}
        {{#error}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-6">
            {{error}}
        </div>
        {{/error}}

        <!-- Banner de período activo / inactivo -->
        {{#periodoActivo}}
        <div class="bg-green-50 border border-green-300 text-green-800 px-5 py-3 rounded-xl mb-6 flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-sm font-medium">
                Período activo: <strong>{{periodoNombre}}</strong>
                {{#periodoFin}}&bull; Cierra el {{periodoFin}}{{/periodoFin}}
            </p>
        </div>
        {{/periodoActivo}}
        {{^periodoActivo}}
        <div class="bg-yellow-50 border border-yellow-300 text-yellow-800 px-5 py-3 rounded-xl mb-6 flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-sm font-medium">
                No hay un período de inscripción activo. La inscripción está cerrada por el momento.
            </p>
        </div>
        {{/periodoActivo}}

        <!-- Listado de materias -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden">
            <div class="px-6 py-4 bg-violet-50 border-b border-violet-100">
                <h2 class="text-xl font-bold text-violet-700">Todas las materias</h2>
            </div>

            {{#materias}}
            <div class="border-b border-gray-100 px-6 py-4 flex items-center justify-between gap-4">
                <div class="flex-1">
                    <p class="font-semibold text-gray-800">{{nombre}}</p>
                    <p class="text-gray-500 text-sm">
                        Código: <span class="font-medium">{{codigo}}</span>
                        {{#descripcion}}&bull; {{descripcion}}{{/descripcion}}
                    </p>
                </div>
                <div class="flex-shrink-0">
                    {{#inscripto}}
                    <span class="inline-flex items-center gap-1 text-xs bg-green-100 text-green-700 border border-green-300 px-3 py-1 rounded-lg font-medium">
                        ✓ Inscripto
                        {{#fechaInscripcion}}<span class="text-green-500 font-normal ml-1">({{fechaInscripcion}})</span>{{/fechaInscripcion}}
                    </span>
                    {{/inscripto}}
                    {{^inscripto}}
                    {{#periodoActivo}}
                    <form action="/materia/inscribirse/{{id}}" method="POST" style="display:inline">
                        <button type="submit"
                                class="text-xs bg-violet-600 text-white px-4 py-1.5 rounded-lg hover:bg-violet-700 transition font-medium">
                            Inscribirse
                        </button>
                    </form>
                    {{/periodoActivo}}
                    {{^periodoActivo}}
                    <span class="text-xs text-gray-400">No disponible</span>
                    {{/periodoActivo}}
                    {{/inscripto}}
                </div>
            </div>
            {{/materias}}

            {{^materias}}
            <div class="px-6 py-10 text-center text-gray-400">
                <p>No hay materias registradas en el sistema.</p>
            </div>
            {{/materias}}
        </div>

        <div class="mt-4 text-center">
            <a href="/mis-materias" class="text-violet-600 hover:underline text-sm">Ver mis materias inscriptas &rarr;</a>
        </div>

    </div>
</body>
</html>
