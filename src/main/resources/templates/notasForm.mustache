<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notas — {{materiaNombre}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
    <div class="max-w-3xl mx-auto">

        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">Carga de Notas</h1>
                <p class="text-gray-500 text-sm mt-1">
                    {{materiaNombre}}
                    {{#materiaCodigo}}<span class="text-gray-400">&bull; {{materiaCodigo}}</span>{{/materiaCodigo}}
                </p>
            </div>
            <a href="/materias/listar" class="text-gray-500 hover:text-gray-700 text-sm">&larr; Volver a materias</a>
        </div>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg mb-6">
            {{successMessage}}
        </div>
        {{/successMessage}}
        {{#error}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-6">
            {{error}}
        </div>
        {{/error}}

        <!-- Formulario de notas -->
        <form action="/materia/{{materiaId}}/notas" method="POST">
            <div class="bg-white rounded-2xl shadow-md overflow-hidden">

                <!-- Encabezado de la tabla -->
                <div class="px-6 py-4 bg-violet-50 border-b border-violet-100">
                    <h2 class="text-xl font-bold text-violet-700">Alumnos inscriptos</h2>
                    <p class="text-sm text-gray-500 mt-1">
                        Ingresá una nota entre 0 y 10. Dejá el campo vacío para no cargar nota aún.
                    </p>
                </div>

                {{#alumnos}}
                <div class="border-b border-gray-100 px-6 py-4 flex items-center justify-between gap-4">
                    <div class="flex-1">
                        <p class="font-medium text-gray-800">{{alumnoApellido}}, {{alumnoNombre}}</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <label for="nota_{{alumnoId}}" class="text-sm text-gray-500 sr-only">
                            Nota de {{alumnoNombre}} {{alumnoApellido}}
                        </label>
                        <input
                            type="number"
                            id="nota_{{alumnoId}}"
                            name="nota_{{alumnoId}}"
                            value="{{nota}}"
                            min="0"
                            max="10"
                            step="0.5"
                            placeholder="—"
                            class="w-24 text-center px-3 py-2 border border-gray-300 rounded-lg
                                   focus:outline-none focus:ring-2 focus:ring-violet-500
                                   text-gray-800 font-semibold">
                    </div>
                </div>
                {{/alumnos}}

                {{^alumnos}}
                <div class="px-6 py-10 text-center text-gray-400">
                    <p>No hay alumnos registrados en el sistema.</p>
                    <p class="text-sm mt-1">
                        <a href="/alumno/registrar" class="text-violet-600 hover:underline">
                            Registrar un alumno
                        </a>
                    </p>
                </div>
                {{/alumnos}}

            </div>

            {{#alumnos.0}}
            <!-- Mostrar el botón solo si existe al menos un alumno -->
            <div class="mt-6 flex justify-end">
                <button type="submit"
                        class="bg-violet-600 text-white px-8 py-3 rounded-xl
                            hover:bg-violet-700 font-semibold transition shadow-sm">
                    Guardar Notas
                </button>
            </div>
            {{/alumnos.0}}

        </form>

        {{!-- TODO: Cuando se implemente condición (REGULAR / LIBRE), agregar aquí
              una columna adicional. La tabla alumnos_materias ya tiene la estructura
              preparada para recibirla. --}}

    </div>
</body>
</html>
