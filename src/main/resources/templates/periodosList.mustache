<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Períodos de Inscripción</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
    <div class="max-w-4xl mx-auto">

        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">Períodos de Inscripción</h1>
                <p class="text-gray-500 text-sm mt-1">Alta, edición y eliminación de períodos</p>
            </div>
            <a href="/dashboard" class="text-gray-500 hover:text-gray-700 text-sm">&larr; Volver al panel</a>
        </div>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg mb-6">
            {{successMessage}}
        </div>
        {{/successMessage}}
        {{#error}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-6">
            {{error}}
        </div>
        {{/error}}

        <!-- Listado de períodos -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden">
            <div class="flex items-center justify-between px-6 py-4 bg-violet-50 border-b border-violet-100">
                <h2 class="text-xl font-bold text-violet-700">Períodos registrados</h2>
                <a href="/periodo/registrar"
                   class="inline-flex items-center gap-1 bg-violet-600 text-white px-4 py-2 rounded-lg hover:bg-violet-700 transition text-sm font-medium">
                    + Nuevo período
                </a>
            </div>

            {{#periodos}}
            <div class="border-b border-gray-100 px-6 py-4">
                <div class="flex items-start justify-between">
                    <div>
                        <p class="font-semibold text-gray-800">{{nombre}}</p>
                        <p class="text-gray-500 text-sm mt-1">
                            Tipo: <span class="font-medium text-violet-700">{{tipo}}</span>
                            &bull; {{fechaInicio}} → {{fechaFin}}
                        </p>
                        <p class="text-xs mt-1 text-gray-500">
                            Estado: <span class="font-semibold text-gray-700">{{estado}}</span>
                        </p>
                    </div>
                    <div class="flex gap-2 ml-4 flex-shrink-0">
                        <a href="/periodo/editar/{{id}}"
                           class="text-xs bg-yellow-100 text-yellow-700 border border-yellow-300 px-3 py-1 rounded-lg hover:bg-yellow-200 transition font-medium">
                            Editar
                        </a>
                        <a href="/periodo/eliminar/{{id}}"
                           onclick="return confirm('¿Eliminar el período {{nombre}}?')"
                           class="text-xs bg-red-100 text-red-700 border border-red-300 px-3 py-1 rounded-lg hover:bg-red-200 transition font-medium">
                            Eliminar
                        </a>
                    </div>
                </div>
            </div>
            {{/periodos}}

            {{^periodos}}
            <div class="px-6 py-10 text-center text-gray-400">
                <p>No hay períodos de inscripción registrados.</p>
            </div>
            {{/periodos}}
        </div>

        {{!-- TODO: Cuando se implemente InscripcionMateria / InscripcionExamen,
              este listado puede complementarse mostrando el período activo por tipo,
              usando PeriodoInscripcion.getPeriodoActivoMaterias()
              y PeriodoInscripcion.getPeriodoActivoExamenes() desde App.java. --}}

    </div>
</body>
</html>
