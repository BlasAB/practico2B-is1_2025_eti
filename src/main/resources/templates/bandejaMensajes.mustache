<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bandeja de Entrada</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-4">
    <div class="max-w-4xl mx-auto">

        <h1 class="text-3xl font-bold text-center text-gray-800 mb-8">Bandeja de Entrada</h1>

        {{#mensajes}}
        <div class="bg-white rounded-lg shadow-md p-6 mb-4">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="md:col-span-2">
                    <h2 class="text-xl font-semibold text-gray-800">{{asunto}}</h2>
                    <p class="text-gray-600 text-sm mt-1">
                        De: <span class="font-medium">{{remitenteNombre}}</span>
                    </p>
                    <p class="text-gray-700 mt-3 text-sm whitespace-pre-wrap">{{contenido}}</p>
                </div>
                <div class="text-right">
                    {{#fechaEnvio}}
                    <p class="text-gray-400 text-xs">{{fechaEnvio}}</p>
                    {{/fechaEnvio}}
                </div>
            </div>
        </div>
        {{/mensajes}}

        {{^mensajes}}
        <div class="bg-white rounded-lg shadow-md p-8 text-center">
            <p class="text-gray-600 text-lg">No tenés mensajes en tu bandeja de entrada.</p>
        </div>
        {{/mensajes}}

        <div class="mt-8 text-center space-y-4">
            <a href="/mensaje/nuevo"
               class="inline-block bg-sky-600 text-white px-6 py-3 rounded-lg hover:bg-sky-700 transition duration-200 font-medium">
                Nuevo Mensaje
            </a>
            <br>
            <a href="/dashboard"
               class="inline-block bg-gray-600 text-white px-6 py-3 rounded-lg hover:bg-gray-700 transition duration-200 font-medium">
                Volver al Panel
            </a>
        </div>

        {{!-- TODO: Cuando se implemente el marcado de mensajes como leídos,
              agregar aquí un indicador visual de mensajes no leídos por item. --}}

    </div>
</body>
</html>
