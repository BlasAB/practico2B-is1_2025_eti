<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mis Exámenes</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
    <div class="max-w-3xl mx-auto">

        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">Mis Exámenes</h1>
                <p class="text-gray-500 text-sm mt-1">
                    {{alumnoApellido}}, {{alumnoNombre}}
                </p>
            </div>
            <a href="/dashboard" class="text-gray-500 hover:text-gray-700 text-sm">&larr; Volver al panel</a>
        </div>

        <div class="bg-white rounded-2xl shadow-md overflow-hidden">
            <div class="px-6 py-4 bg-orange-50 border-b border-orange-100 flex items-center justify-between">
                <h2 class="text-xl font-bold text-orange-700">Exámenes inscriptos</h2>
                <a href="/examenes/disponibles"
                   class="text-sm bg-orange-600 text-white px-4 py-1.5 rounded-lg hover:bg-orange-700 transition font-medium">
                    + Inscribirse a más
                </a>
            </div>

            {{#examenes}}
            <div class="border-b border-gray-100 px-6 py-4">
                <p class="font-semibold text-gray-800">{{materiaNombre}}</p>
                <p class="text-gray-500 text-sm">
                    {{fecha}}
                    {{#hora}}&bull; {{hora}}{{/hora}}
                    {{#turno}}&bull; Turno {{turno}}{{/turno}}
                    {{#fechaInscripcion}}&bull; Inscripto el {{fechaInscripcion}}{{/fechaInscripcion}}
                </p>
            </div>
            {{/examenes}}

            {{^tieneExamenes}}
            <div class="px-6 py-10 text-center text-gray-400">
                <p>No estás inscripto a ningún examen todavía.</p>
                <p class="mt-2">
                    <a href="/examenes/disponibles" class="text-orange-600 hover:underline text-sm">
                        Ver exámenes disponibles &rarr;
                    </a>
                </p>
            </div>
            {{/tieneExamenes}}
        </div>

        {{!-- TODO: Cuando se implemente actas de examen / nota_final,
              agregar aquí una columna con el resultado obtenido
              leyendo inscripciones_examenes.nota_final. --}}

    </div>
</body>
</html>
