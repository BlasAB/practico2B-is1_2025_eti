<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mis Notas</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
    <div class="max-w-3xl mx-auto">

        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">Mis Notas</h1>
                <p class="text-gray-500 text-sm mt-1">
                    {{alumnoApellido}}, {{alumnoNombre}}
                </p>
            </div>
            <a href="/dashboard" class="text-gray-500 hover:text-gray-700 text-sm">&larr; Volver al panel</a>
        </div>

        <!-- Promedio general (solo si hay notas) -->
        {{#promedio}}
        <div class="bg-rose-50 border border-rose-200 px-5 py-3 rounded-xl mb-6 flex items-center justify-between">
            <p class="text-sm text-rose-700 font-medium">Promedio general</p>
            <span class="text-2xl font-bold text-rose-700">{{promedio}}</span>
        </div>
        {{/promedio}}

        <div class="bg-white rounded-2xl shadow-md overflow-hidden">
            <div class="px-6 py-4 bg-rose-50 border-b border-rose-100">
                <h2 class="text-xl font-bold text-rose-700">Notas por materia</h2>
            </div>

            {{#tieneNotas}}
            <!-- Encabezado de tabla -->
            <div class="grid grid-cols-3 px-6 py-2 bg-gray-50 border-b border-gray-200 text-xs font-semibold text-gray-500 uppercase tracking-wide">
                <div class="col-span-2">Materia</div>
                <div class="text-right">Nota</div>
            </div>
            {{/tieneNotas}}

            {{#notas}}
            <div class="grid grid-cols-3 px-6 py-4 border-b border-gray-100 items-center">
                <div class="col-span-2">
                    <p class="font-semibold text-gray-800">{{materiaNombre}}</p>
                    <p class="text-gray-400 text-xs">{{materiaCodigo}}</p>
                </div>
                <div class="text-right">
                    <span class="inline-block bg-rose-100 text-rose-700 border border-rose-200 px-3 py-1 rounded-lg font-bold text-sm">
                        {{nota}}
                    </span>
                </div>
            </div>
            {{/notas}}

            {{^tieneNotas}}
            <div class="px-6 py-10 text-center text-gray-400">
                <p>Todavía no tenés notas cargadas.</p>
                <p class="text-sm mt-1">Las notas son cargadas por tus profesores.</p>
            </div>
            {{/tieneNotas}}
        </div>

        {{!-- TODO: Cuando se implemente historial academico completo,
              agregar aquí el estado de cada materia (CURSANDO / APROBADA / REPROBADA)
              leyendo alumnos_materias.condicion y alumnos_materias.estado. --}}

    </div>
</body>
</html>
