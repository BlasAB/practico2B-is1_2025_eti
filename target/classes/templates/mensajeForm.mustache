<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nuevo Mensaje</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-sky-50 to-cyan-100 flex items-center justify-center min-h-screen p-4">
    <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-lg">

        <div class="flex items-center mb-6">
            <svg class="w-8 h-8 text-sky-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <h1 class="text-2xl font-bold text-gray-800">Nuevo Mensaje</h1>
        </div>

        <!-- Remitente (solo lectura, viene de la sesión) -->
        <div class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 mb-5 text-sm text-gray-500">
            Enviando como: <span class="font-semibold text-gray-700">{{remitenteNombre}}</span>
        </div>

        {{#error}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-4">
            {{error}}
        </div>
        {{/error}}

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg mb-4">
            {{successMessage}}
        </div>
        {{/successMessage}}

        <form action="/mensaje/enviar" method="POST" class="space-y-4">

            <div>
                <label for="destinatario_id" class="block text-gray-700 text-sm font-medium mb-1">
                    Destinatario:
                </label>
                <select id="destinatario_id" name="destinatario_id" required
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-sky-500 bg-white">
                    <option value="">-- Seleccionar destinatario --</option>
                    {{#destinatarios}}
                    <option value="{{userId}}">{{nombreCompleto}} ({{tipo}})</option>
                    {{/destinatarios}}
                </select>
            </div>

            <div>
                <label for="asunto" class="block text-gray-700 text-sm font-medium mb-1">Asunto:</label>
                <input type="text" id="asunto" name="asunto" value="{{asunto}}" required maxlength="200"
                       placeholder="Asunto del mensaje"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-sky-500">
            </div>

            <div>
                <label for="contenido" class="block text-gray-700 text-sm font-medium mb-1">Mensaje:</label>
                <textarea id="contenido" name="contenido" rows="6" required
                          placeholder="Escribí tu mensaje aquí..."
                          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-sky-500 resize-none">{{contenido}}</textarea>
            </div>

            <button type="submit"
                    class="w-full bg-sky-600 text-white py-2 px-4 rounded-lg hover:bg-sky-700 font-semibold transition mt-2">
                Enviar mensaje
            </button>
        </form>

        <div class="mt-4 text-center">
            <a href="/dashboard" class="text-gray-500 hover:text-gray-700 text-sm">&larr; Volver al panel</a>
        </div>

        {{!-- TODO: Cuando se implemente Bandeja de Entrada, agregar aquí un enlace
              a /mensajes/bandeja para que el usuario pueda ver sus mensajes recibidos. --}}

    </div>
</body>
</html>
