<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Control</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
    <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-2xl">

        {{#esAlumno}}
        <div class="flex items-center mb-2">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
                Alumno
            </span>
        </div>
        {{/esAlumno}}
        {{#esProfesor}}
        <div class="flex items-center mb-2">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                Profesor
            </span>
        </div>
        {{/esProfesor}}

        <h1 class="text-3xl font-bold text-gray-800 mb-1">Panel de Control</h1>

        {{#username}}
        <p class="text-gray-500 mb-6">Bienvenido/a, <span class="font-semibold text-gray-700">{{username}}</span></p>
        {{/username}}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
            {{#esAlumno}}
            <div class="bg-blue-50 border border-blue-200 p-5 rounded-xl">
                <h2 class="text-lg font-bold text-blue-700 mb-2">Mis Materias</h2>
                <p class="text-gray-600 text-sm mb-3">Consultá las materias disponibles.</p>
                <a href="/materias/listar" class="inline-block bg-blue-600 text-white py-1.5 px-4 rounded-lg hover:bg-blue-700 transition text-sm font-medium">Ver Materias</a>
            </div>
            <div class="bg-indigo-50 border border-indigo-200 p-5 rounded-xl">
                <h2 class="text-lg font-bold text-indigo-700 mb-2">Mi Perfil</h2>
                <p class="text-gray-600 text-sm mb-3">Consultá tu información registrada.</p>
                <a href="#" class="inline-block bg-indigo-600 text-white py-1.5 px-4 rounded-lg hover:bg-indigo-700 transition text-sm font-medium">Ver Perfil</a>
            </div>
            {{/esAlumno}}

            {{#esProfesor}}
            <div class="bg-green-50 border border-green-200 p-5 rounded-xl">
                <h2 class="text-lg font-bold text-green-700 mb-2">Materias</h2>
                <p class="text-gray-600 text-sm mb-3">Consultá las materias del sistema.</p>
                <a href="/materias/listar" class="inline-block bg-green-600 text-white py-1.5 px-4 rounded-lg hover:bg-green-700 transition text-sm font-medium">Ver Materias</a>
            </div>
            <div class="bg-teal-50 border border-teal-200 p-5 rounded-xl">
                <h2 class="text-lg font-bold text-teal-700 mb-2">Mi Perfil</h2>
                <p class="text-gray-600 text-sm mb-3">Consultá tu información registrada.</p>
                <a href="#" class="inline-block bg-teal-600 text-white py-1.5 px-4 rounded-lg hover:bg-teal-700 transition text-sm font-medium">Ver Perfil</a>
            </div>
            {{/esProfesor}}

            {{^esAlumno}}{{^esProfesor}}
            <div class="bg-gray-50 border border-gray-200 p-5 rounded-xl">
                <h2 class="text-lg font-bold text-gray-700 mb-2">Materias</h2>
                <a href="/materias/listar" class="inline-block bg-gray-600 text-white py-1.5 px-4 rounded-lg hover:bg-gray-700 transition text-sm font-medium">Ver Materias</a>
            </div>
            {{/esProfesor}}{{/esAlumno}}
        </div>

        <div class="text-center">
            <a href="/logout"
               class="inline-flex items-center gap-2 bg-red-500 text-white py-2 px-6 rounded-lg hover:bg-red-600 transition font-semibold">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
                Cerrar Sesión
            </a>
        </div>
    </div>
</body>
</html>
