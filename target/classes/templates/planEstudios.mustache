<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plan de Estudios — {{carreraNombre}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
    <div class="max-w-3xl mx-auto">

        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">Plan de Estudios</h1>
                <p class="text-gray-500 text-sm mt-1">
                    {{carreraNombre}}
                    {{#carreraCodigo}}<span class="text-gray-400">&bull; {{carreraCodigo}}</span>{{/carreraCodigo}}
                </p>
            </div>
            <a href="/carreras" class="text-gray-500 hover:text-gray-700 text-sm">&larr; Volver a carreras</a>
        </div>

        {{#tieneAnios}}
        {{#anios}}
        <div class="bg-white rounded-2xl shadow-md overflow-hidden mb-6">
            <div class="px-6 py-4 bg-teal-50 border-b border-teal-100">
                <h2 class="text-lg font-bold text-teal-700">{{anioNombre}}</h2>
            </div>
            {{#materias}}
            <div class="border-b border-gray-100 px-6 py-3">
                <p class="font-semibold text-gray-800">{{nombre}}</p>
                <p class="text-gray-500 text-sm">
                    Código: <span class="font-medium">{{codigo}}</span>
                    {{#descripcion}}&bull; {{descripcion}}{{/descripcion}}
                </p>
            </div>
            {{/materias}}
            {{^materias}}
            <div class="px-6 py-4 text-gray-400 text-sm">No hay materias en este año.</div>
            {{/materias}}
        </div>
        {{/anios}}
        {{/tieneAnios}}

        {{^tieneAnios}}
        <div class="bg-white rounded-2xl shadow-md px-6 py-10 text-center text-gray-400">
            <p>Esta carrera no tiene materias asignadas en su plan de estudios.</p>
        </div>
        {{/tieneAnios}}

        {{!-- TODO: Cuando se implemente correlatividades, mostrar aquí
              los requisitos previos de cada materia.
              La estructura carrera_materias ya tiene columna lista para
              agregar correlativa_id como FK. --}}

    </div>
</body>
</html>
