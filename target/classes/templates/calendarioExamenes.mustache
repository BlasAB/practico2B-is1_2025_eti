<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calendario de Exámenes</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-4">
    <div class="max-w-4xl mx-auto">

        <h1 class="text-3xl font-bold text-center text-gray-800 mb-8">Calendario de Exámenes Finales</h1>

        {{#examenes}}
        <div class="bg-white rounded-lg shadow-md p-6 mb-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <h2 class="text-xl font-semibold text-gray-800">{{materiaNombre}}</h2>
                    <p class="text-gray-600">
                        {{fecha}}
                        {{#hora}}&nbsp;&bull;&nbsp;{{hora}}{{/hora}}
                    </p>
                    {{#observaciones}}
                    <p class="text-gray-400 text-sm mt-1">{{observaciones}}</p>
                    {{/observaciones}}
                </div>
                <div class="text-right">
                    {{#turno}}
                    <span class="inline-block bg-violet-100 text-violet-700 text-sm font-medium px-3 py-1 rounded-full">
                        Turno {{turno}}
                    </span>
                    {{/turno}}
                </div>
            </div>
        </div>
        {{/examenes}}

        {{^examenes}}
        <div class="bg-white rounded-lg shadow-md p-8 text-center">
            <p class="text-gray-600 text-lg">No hay fechas de exámenes registradas.</p>
        </div>
        {{/examenes}}

        <div class="mt-8 text-center">
            <a href="/dashboard"
               class="inline-block bg-gray-600 text-white px-6 py-3 rounded-lg hover:bg-gray-700 transition duration-200 font-medium">
                Volver al Panel
            </a>
        </div>

    </div>
</body>
</html>
